-- TAB 1 - Player Viewer
-- ================================================
UI.AddTab("Player Viewer", function(tab)
    local playerNames = {}
    for _, p in ipairs(_players) do table.insert(playerNames, p.Name) end

    local sel = tab:Section("Players", "Left")
    sel:Combo("pv_player", "Player", playerNames, 0)
    sel:Spacing()
    sel:Text("Last: " .. _lastRefresh)
    sel:Button("Refresh Player List", function()
        _manualRefresh = true
        notify("Player list refreshed!", "Player Viewer", 2)
    end)
    sel:Spacing()
    sel:Combo("pv_view", "View", VIEWS, 0)
    sel:Spacing()
    sel:Text("* = You")
    sel:Spacing()

    local esp = tab:Section("ESP", "Left")
    esp:Toggle("esp_on", "Enable ESP", false, function(state)
        notify(state and "ESP Enabled" or "ESP Disabled", "ESP", 2)
    end)
    local kb = esp:Keybind("esp_kb", 0x2D, "toggle")
    kb:AddToHotkey("ESP", "esp_on")
    esp:Spacing()
    esp:Toggle("esp_name",  "Names",    true)
    esp:Toggle("esp_lvl",   "Level",    true)
    esp:Toggle("esp_money", "Money",    true)
    esp:Toggle("esp_dist",  "Distance", true)
    esp:Spacing()
    esp:SliderInt("esp_maxdist", "Max Distance", 50, 2000, 500)
    esp:Tip("Hides ESP beyond this range (studs)")
    esp:SliderInt("esp_size", "Font Size", 8, 20, 13)
    esp:Spacing()
    esp:Button("ESP Status", function()
        local count = 0
        for _ in pairs(_espObjects) do count = count + 1 end
        notify("on=" .. tostring(_espOn) .. " visible=" .. count .. " players=" .. #_players, "ESP", 4)
    end)

    local pIdx    = UI.GetValue("pv_player") or 0
    local viewIdx = UI.GetValue("pv_view")   or 0
    local target  = _players[pIdx + 1]
    local out     = tab:Section("Data", "Right", nil, 600)

    if not target then out:Text("No players found. Hit Refresh!"); return end

    local isLocal = (target == game.Players.LocalPlayer)
    out:Text((isLocal and "* " or "  ") .. target.Name)
    out:Spacing()

    local data     = target:FindFirstChild("Data")
    local backpack = target:FindFirstChild("Backpack")
    local function hdr(t) out:Text("[ " .. t .. " ]") end

    if viewIdx == 0 then
        hdr("Economy")
        out:Text("Money        " .. getVal(data, "Money"))
        out:Text("Bank         " .. getVal(data, "Bank"))
        out:Text("Crypto       " .. getVal(data, "Crypto"))
        out:Text("DOGE         " .. getVal(data, "DOGE"))
        out:Text("ETH          " .. getVal(data, "ETH"))
        out:Spacing()
        hdr("Combat & Stats")
        out:Text("Level        " .. getVal(data, "Level"))
        out:Text("XP           " .. getVal(data, "XP"))
        out:Text("Strength     " .. getVal(data, "Strength"))
        out:Text("Stamina      " .. getVal(data, "Stamina"))
        out:Text("PlayTime     " .. getVal(data, "PlayTime"))
        out:Text("Jailed       " .. getVal(data, "Jailed"))
        out:Spacing()
        hdr("Season & Spins")
        out:Text("Season       " .. getVal(data, "Season"))
        out:Text("Spins        " .. getVal(data, "Spins"))
        out:Text("LuckySpins   " .. getVal(data, "LuckySpins"))
        out:Text("CurrentDay   " .. getVal(data, "CurrentDay"))
        out:Spacing()
        hdr("Appearance")
        out:Text("Clothing     " .. getVal(data, "Clothing"))
        out:Text("Accessories  " .. getVal(data, "Accessories"))
        out:Text("Jewelry      " .. getVal(data, "Jewelry"))
        out:Text("Tattoos      " .. getVal(data, "OwnedTattoos"))
        out:Text("Emoji        " .. getVal(data, "Emoji"))
        out:Text("Misc         " .. getVal(data, "Misc"))
        out:Spacing()
        hdr("Identity")
        out:Text("Gang         " .. getVal(data, "Gang"))
        out:Text("Tier         " .. getVal(data, "Tier"))
        out:Text("Job          " .. getVal(data, "Job"))
        out:Text("Quests       " .. getVal(data, "Quests"))
        out:Text("Passes       " .. getVal(data, "Passes"))
        out:Text("IsClaimed    " .. getVal(data, "IsClaimed"))

    elseif viewIdx == 1 then
        local safeFolder = data and data:FindFirstChild("SafeItems")
        local items      = safeFolder and safeFolder:GetChildren() or {}
        local total, priced, unpriced = calcSafeValue(target)
        hdr("Safe Items  (" .. #items .. ")")
        out:Text("Est. Value   $" .. fmtMoney(total))
        out:Text("Priced: " .. priced .. "   Unpriced: " .. unpriced)
        out:Spacing()
        if #items == 0 then
            out:Text("Safe is empty.")
        else
            local grouped, order = {}, {}
            for _, item in ipairs(items) do
                if not grouped[item.Name] then grouped[item.Name] = {}; table.insert(order, item.Name) end
                table.insert(grouped[item.Name], item.Value)
            end
            table.sort(order, function(a, b) return (ITEM_PRICES[a] or 0) > (ITEM_PRICES[b] or 0) end)
            for _, name in ipairs(order) do
                local stack = grouped[name]
                local price = ITEM_PRICES[name]
                out:Text(name .. "  x" .. #stack .. (price and ("  ~$" .. fmtMoney(price) .. " ea") or "  (no price)"))
                for i, val in ipairs(stack) do
                    local p    = val:split(" ")
                    local cond = tonumber(p[1]) or 100
                    local ctag = cond >= 70 and (p[1].."% (good)") or cond >= 40 and (p[1].."% (fair)") or (p[1].."% (low)")
                    out:Text("  " .. i .. ")  Cond: " .. ctag .. "   Ammo: " .. (p[2] or "?"))
                end
                out:Spacing()
            end
        end

    elseif viewIdx == 2 then
        local tools = {}
        if backpack then
            for _, tool in ipairs(backpack:GetChildren()) do
                if tool:IsA("Tool") then table.insert(tools, tool.Name) end
            end
        end
        hdr("Backpack  (" .. #tools .. " tools)")
        out:Spacing()
        if #tools == 0 then out:Text("Backpack is empty.")
        else for i, name in ipairs(tools) do out:Text(i .. ".  " .. name) end end
        out:Spacing()
        local trunkList = (data and data:FindFirstChild("TrunkItems") and data.TrunkItems:GetChildren()) or {}
        hdr("Trunk  (" .. #trunkList .. " items)")
        out:Spacing()
        if #trunkList == 0 then out:Text("Trunk is empty.")
        else
            for _, item in ipairs(trunkList) do
                out:Text(item.Name .. "  =  " .. (item:IsA("ValueBase") and tostring(item.Value) or item.ClassName))
            end
        end

    elseif viewIdx == 3 then
        local list = (data and data:FindFirstChild("Settings") and data.Settings:GetChildren()) or {}
        hdr("Player Settings  (" .. #list .. ")")
        out:Spacing()
        if #list == 0 then out:Text("No settings found.")
        else for _, s in ipairs(list) do out:Text(s.Name .. "   " .. tostring(s.Value)) end end
    end
end)

