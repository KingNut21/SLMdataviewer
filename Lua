local ITEM_PRICES = {
    ["ARPSwitch"]           = 15000,
    ["Binary 300 BLACKOUT"] = 25000,
    ["EasterDraco"]         = 35000,
    ["BlueTipSwitch"]       = 20000,
    ["BinaryDraco"]         = 30000,
}

local VIEWS = {"Stats", "Safe", "Backpack", "Settings"}

-- Shared state
local _players       = {}
local _richMoney     = {name = "?", val = 0}
local _richSafe      = {name = "?", val = 0}
local _espObjects    = {}
local _lastRefresh   = "Never"
local _manualRefresh = false

-- Helpers
local function getVal(data, name)
    local obj = data and data:FindFirstChild(name)
    return obj and tostring(obj.Value) or "N/A"
end

local function fmtMoney(n)
    n = tonumber(n) or 0
    local s, result, count = tostring(math.floor(n)), "", 0
    for i = #s, 1, -1 do
        if count > 0 and count % 3 == 0 then result = "," .. result end
        result = s:sub(i, i) .. result
        count  = count + 1
    end
    return result
end

local function calcSafeValue(player)
    local data       = player:FindFirstChild("Data")
    local safeFolder = data and data:FindFirstChild("SafeItems")
    if not safeFolder then return 0, 0, 0 end
    local total, priced, unpriced = 0, 0, 0
    for _, item in ipairs(safeFolder:GetChildren()) do
        local price = ITEM_PRICES[item.Name]
        if price then
            local cond = tonumber(item.Value:split(" ")[1]) or 100
            total   = total + math.floor(price * (cond / 100))
            priced  = priced + 1
        else
            unpriced = unpriced + 1
        end
    end
    return total, priced, unpriced
end

local function doRefresh()
    local list = game.Players:GetPlayers()
    _players   = list
    local bMoney, bMoneyV, bSafe, bSafeV = "?", 0, "?", 0
    for _, p in ipairs(list) do
        local data  = p:FindFirstChild("Data")
        local money = tonumber(data and data:FindFirstChild("Money") and data.Money.Value) or 0
        if money > bMoneyV then bMoneyV = money; bMoney = p.Name end
        local sv = calcSafeValue(p)
        if sv > bSafeV then bSafeV = sv; bSafe = p.Name end
    end
    _richMoney   = {name = bMoney, val = bMoneyV}
    _richSafe    = {name = bSafe,  val = bSafeV}
    _lastRefresh = #list .. " players"
end

-- Auto + manual refresh loop
spawn(function()
    while true do
        pcall(doRefresh)
        local t = 0
        while t < 3 do
            task.wait(0.1); t = t + 0.1
            if _manualRefresh then _manualRefresh = false; break end
        end
    end
end)

-- ESP helpers
local function getESP(name)
    if not _espObjects[name] then
        local nl = Drawing.new("Text")
        nl.Outline = true; nl.Center = true; nl.Size = 14
        nl.Color   = Color3.new(1, 0.9, 0.31); nl.Visible = false
        local il = Drawing.new("Text")
        il.Outline = true; il.Center = true; il.Size = 12
        il.Color   = Color3.new(0.63, 0.78, 1); il.Visible = false
        local dl = Drawing.new("Text")
        dl.Outline = true; dl.Center = true; dl.Size = 11
        dl.Color   = Color3.new(0.7, 1, 0.7); dl.Visible = false
        _espObjects[name] = {nameLabel = nl, infoLabel = il, distLabel = dl}
    end
    return _espObjects[name]
end

local function hideESP(name)
    local e = _espObjects[name]
    if e then e.nameLabel.Visible = false; e.infoLabel.Visible = false; e.distLabel.Visible = false end
end

local function removeESP(name)
    local e = _espObjects[name]
    if e then e.nameLabel:Remove(); e.infoLabel:Remove(); e.distLabel:Remove(); _espObjects[name] = nil end
end

-- ESP cached settings (polled every 15 frames to save CPU)
local _espOn      = false
local _espName    = true
local _espLvl     = true
local _espMon     = true
local _espDist    = true
local _espMaxDist = 500   -- stud culling distance
local _espSize    = 13    -- font size
local _espPoll    = 0

spawn(function()
    local localP = game.Players.LocalPlayer

    while true do
        task.wait(0.05)

        -- Poll UI settings every 15 ticks (~0.75s)
        _espPoll = _espPoll + 1
        if _espPoll >= 15 then
            _espPoll     = 0
            _espOn       = UI.GetValue("esp_on")      or false
            _espName     = UI.GetValue("esp_name")    or false
            _espLvl      = UI.GetValue("esp_lvl")     or false
            _espMon      = UI.GetValue("esp_money")   or false
            _espDist     = UI.GetValue("esp_dist")    or false
            _espMaxDist  = UI.GetValue("esp_maxdist") or 500
            _espSize     = UI.GetValue("esp_size")    or 13
        end

        if not _espOn then
            -- ESP off: hide all, do nothing else
            for name in pairs(_espObjects) do hideESP(name) end
        else
            local localChr = workspace:FindFirstChild(localP.Name)
            local localHRP = localChr and localChr:FindFirstChild("HumanoidRootPart")
            local lx = localHRP and localHRP.Position.X or 0
            local ly = localHRP and localHRP.Position.Y or 0
            local lz = localHRP and localHRP.Position.Z or 0
            local active = {}

            for _, player in ipairs(_players) do
                if player ~= localP then
                    active[player.Name] = true
                    local char = workspace:FindFirstChild(player.Name)
                    local hrp  = char and char:FindFirstChild("HumanoidRootPart")

                    if hrp then
                        local px = hrp.Position.X
                        local py = hrp.Position.Y
                        local pz = hrp.Position.Z

                        -- Distance cull BEFORE WorldToScreen (cheap math vs expensive API call)
                        local dx   = px - lx
                        local dy   = py - ly
                        local dz   = pz - lz
                        local dist = math.floor(math.sqrt(dx*dx + dy*dy + dz*dz))

                        if dist > _espMaxDist then
                            hideESP(player.Name)
                        else
                            local screenPos, onSc = WorldToScreen(Vector3.new(px, py + 3.5, pz))

                            if screenPos and type(screenPos.X) == "number" then
                                local e    = getESP(player.Name)
                                local data = player:FindFirstChild("Data")
                                local sx   = screenPos.X
                                local sy   = screenPos.Y
                                local lineH = _espSize + 3
                                local curY  = sy

                                -- Line 1: Name
                                if _espName then
                                    e.nameLabel.Text     = player.Name
                                    e.nameLabel.Size     = _espSize
                                    e.nameLabel.Position = Vector2.new(sx, curY)
                                    e.nameLabel.Visible  = onSc
                                    curY = curY + lineH
                                else
                                    e.nameLabel.Visible = false
                                end

                                -- Line 2: Level | $Money (single line, no separate dist label)
                                local info = ""
                                if _espLvl then
                                    local lvl = data and data:FindFirstChild("Level")
                                    info = "[" .. (lvl and tostring(lvl.Value) or "?") .. "]"
                                end
                                if _espMon then
                                    local mon  = data and data:FindFirstChild("Money")
                                    local ms   = tostring(math.floor(tonumber(mon and mon.Value) or 0))
                                    info = info .. (#info > 0 and " $" or "$") .. ms
                                end
                                if _espDist then
                                    info = info .. (#info > 0 and " " or "") .. dist .. "m"
                                end

                                if #info > 0 then
                                    e.infoLabel.Text     = info
                                    e.infoLabel.Size     = _espSize - 2
                                    e.infoLabel.Position = Vector2.new(sx, curY)
                                    e.infoLabel.Visible  = onSc
                                else
                                    e.infoLabel.Visible = false
                                end

                                -- Distance label hidden (merged into info line)
                                e.distLabel.Visible = false
                            else
                                hideESP(player.Name)
                            end
                        end
                    else
                        hideESP(player.Name)
                    end
                end
            end

            for name in pairs(_espObjects) do
                if not active[name] then removeESP(name) end
            end
        end
    end
end)

