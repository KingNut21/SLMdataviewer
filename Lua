UI.AddTab("Item Search", function(tab)
    local searchSec = tab:Section("Search", "Left")
    searchSec:InputText("item_query", "Item Name", "")
    searchSec:Spacing()
    local serverTotal = 0
    for _, player in ipairs(_players) do
        serverTotal = serverTotal + calcSafeValue(player)
    end
    searchSec:Text("Server safe total:")
    searchSec:Text("~$" .. fmtMoney(serverTotal))
    searchSec:Spacing()
    searchSec:Text("Searches all players")
    searchSec:Text("SafeItems live.")

    local resultsSec = tab:Section("Results", "Right", nil, 600)
    local raw        = UI.GetValue("item_query") or ""
    local query      = raw:lower():gsub("^%s+", ""):gsub("%s+$", "")

    if query == "" then
        resultsSec:Text("Enter a name to filter,")
        resultsSec:Text("or browse all safes below:")
        resultsSec:Spacing()
        for _, player in ipairs(_players) do
            local data       = player:FindFirstChild("Data")
            local safeFolder = data and data:FindFirstChild("SafeItems")
            local items      = safeFolder and safeFolder:GetChildren() or {}
            local val        = calcSafeValue(player)
            resultsSec:Text(player.Name .. "  |  " .. #items .. " items  ~$" .. fmtMoney(val))
        end
        return
    end

    local totalFound = 0
    for _, player in ipairs(_players) do
        local data       = player:FindFirstChild("Data")
        local safeFolder = data and data:FindFirstChild("SafeItems")
        if safeFolder then
            local matches = {}
            for _, item in ipairs(safeFolder:GetChildren()) do
                if item.Name:lower():find(query, 1, true) then
                    table.insert(matches, item)
                end
            end
            if #matches > 0 then
                resultsSec:Text(player.Name .. "  (" .. #matches .. ")")
                for _, item in ipairs(matches) do
                    local p     = item.Value:split(" ")
                    local price = ITEM_PRICES[item.Name]
                    local cond  = tonumber(p[1]) or 100
                    local worth = price and math.floor(price * (cond / 100)) or nil
                    local tag   = worth and ("  ~$" .. fmtMoney(worth)) or ""
                    resultsSec:Text("  " .. item.Name .. "  Cond:" .. (p[1] or "?") .. "  Ammo:" .. (p[2] or "?") .. tag)
                end
                resultsSec:Spacing()
                totalFound = totalFound + #matches
            end
        end
    end

    if totalFound == 0 then
        resultsSec:Text("No results for: " .. raw)
    else
        resultsSec:Text("Total: " .. totalFound .. " match(es)")
    end
end)
