-- ================================================
--  Player Data Viewer v2 | Matcha UI
-- ================================================

local ITEM_PRICES = {
    ["ARPSwitch"]           = 15000,
    ["Binary 300 BLACKOUT"] = 25000,
    ["EasterDraco"]         = 35000,
    ["BlueTipSwitch"]       = 20000,
    ["BinaryDraco"]         = 30000,
}

local VIEWS = {"Stats", "Safe", "Backpack", "Settings"}

-- ================================================
-- Shared state
-- ================================================
local _players    = {}
local _richMoney  = {name = "?", val = 0}
local _richSafe   = {name = "?", val = 0}
local _espObjects = {}

-- ================================================
-- Helpers
-- ================================================
local function getVal(data, name)
    local obj = data and data:FindFirstChild(name)
    return obj and tostring(obj.Value) or "N/A"
end

local function fmtMoney(n)
    n = tonumber(n) or 0
    local s      = tostring(math.floor(n))
    local result = ""
    local count  = 0
    for i = #s, 1, -1 do
        if count > 0 and count % 3 == 0 then
            result = "," .. result
        end
        result = s:sub(i, i) .. result
        count  = count + 1
    end
    return result
end

local function calcSafeValue(player)
    local data       = player:FindFirstChild("Data")
    local safeFolder = data and data:FindFirstChild("SafeItems")
    if not safeFolder then return 0, 0, 0 end
    local total, priced, unpriced = 0, 0, 0
    for _, item in ipairs(safeFolder:GetChildren()) do
        local price = ITEM_PRICES[item.Name]
        if price then
            local parts = item.Value:split(" ")
            local cond  = tonumber(parts[1]) or 100
            total   = total + math.floor(price * (cond / 100))
            priced  = priced + 1
        else
            unpriced = unpriced + 1
        end
    end
    return total, priced, unpriced
end

local function refreshPlayers()
    local list = game.Players:GetPlayers()
    _players   = list
    local bestMoney, bestMoneyVal = "?", 0
    local bestSafe,  bestSafeVal  = "?", 0
    for _, p in ipairs(list) do
        local data     = p:FindFirstChild("Data")
        local moneyObj = data and data:FindFirstChild("Money")
        local money    = tonumber(moneyObj and moneyObj.Value) or 0
        if money > bestMoneyVal then
            bestMoneyVal = money
            bestMoney    = p.Name
        end
        local sv = calcSafeValue(p)
        if sv > bestSafeVal then
            bestSafeVal = sv
            bestSafe    = p.Name
        end
    end
    _richMoney = {name = bestMoney, val = bestMoneyVal}
    _richSafe  = {name = bestSafe,  val = bestSafeVal}
end

-- ================================================
-- Auto-refresh loop
-- ================================================
spawn(function()
    while true do
        pcall(refreshPlayers)
        task.wait(3)
    end
end)

-- ================================================
-- ESP
-- ================================================
local function getESP(name)
    if not _espObjects[name] then
        local nl    = Drawing.new("Text")
        nl.Outline  = true
        nl.Center   = true
        nl.FontSize = 14
        nl.Color    = Color3.new(1, 0.9, 0.31)
        nl.Visible  = false

        local il    = Drawing.new("Text")
        il.Outline  = true
        il.Center   = true
        il.FontSize = 12
        il.Color    = Color3.new(0.63, 0.78, 1)
        il.Visible  = false

        local dl    = Drawing.new("Text")
        dl.Outline  = true
        dl.Center   = true
        dl.FontSize = 11
        dl.Color    = Color3.new(0.7, 1, 0.7)
        dl.Visible  = false

        _espObjects[name] = {nameLabel = nl, infoLabel = il, distLabel = dl}
    end
    return _espObjects[name]
end

local function hideESP(name)
    local e = _espObjects[name]
    if e then
        e.nameLabel.Visible = false
        e.infoLabel.Visible = false
        e.distLabel.Visible = false
    end
end

local function removeESP(name)
    local e = _espObjects[name]
    if e then
        e.nameLabel:Remove()
        e.infoLabel:Remove()
        e.distLabel:Remove()
        _espObjects[name] = nil
    end
end

spawn(function()
    while true do
        task.wait(0.05)
        pcall(function()
            local espOn    = UI.GetValue("esp_on")
            local showLvl  = UI.GetValue("esp_lvl")
            local showMon  = UI.GetValue("esp_money")
            local showDist = UI.GetValue("esp_dist")
            local localP   = game.Players.LocalPlayer
            local localChr = workspace:FindFirstChild(localP.Name)
            local localHRP = localChr and localChr:FindFirstChild("HumanoidRootPart")
            local active   = {}

            for _, player in ipairs(_players) do
                if player ~= localP then
                    active[player.Name] = true
                    local char = workspace:FindFirstChild(player.Name)
                    local hrp  = char and char:FindFirstChild("HumanoidRootPart")

                    if hrp and espOn then
                        local headPos = Vector3.new(
                            hrp.Position.X,
                            hrp.Position.Y + 3.5,
                            hrp.Position.Z
                        )
                        local wok, screenPos, onSc = pcall(WorldToScreen, headPos)
                        if wok and screenPos then
                            local esp  = getESP(player.Name)
                            local data = player:FindFirstChild("Data")

                            esp.nameLabel.Text     = player.Name
                            esp.nameLabel.Position = screenPos
                            esp.nameLabel.Visible  = (onSc == true)

                            local parts = {}
                            if showLvl then
                                local lvl = data and data:FindFirstChild("Level")
                                table.insert(parts, "Lvl " .. (lvl and tostring(lvl.Value) or "?"))
                            end
                            if showMon then
                                local mon = data and data:FindFirstChild("Money")
                                table.insert(parts, "$" .. fmtMoney(mon and mon.Value or 0))
                            end

                            if #parts > 0 then
                                esp.infoLabel.Text     = table.concat(parts, "  |  ")
                                esp.infoLabel.Position = Vector2.new(screenPos.X, screenPos.Y + 17)
                                esp.infoLabel.Visible  = (onSc == true)
                            else
                                esp.infoLabel.Visible = false
                            end

                            if showDist and localHRP then
                                local dx   = hrp.Position.X - localHRP.Position.X
                                local dy   = hrp.Position.Y - localHRP.Position.Y
                                local dz   = hrp.Position.Z - localHRP.Position.Z
                                local dist = math.floor(math.sqrt(dx*dx + dy*dy + dz*dz))
                                esp.distLabel.Text     = dist .. " studs"
                                esp.distLabel.Position = Vector2.new(screenPos.X, screenPos.Y + 30)
                                esp.distLabel.Visible  = (onSc == true)
                            else
                                esp.distLabel.Visible = false
                            end
                        else
                            hideESP(player.Name)
                        end
                    else
                        hideESP(player.Name)
                    end
                end
            end

            for name in pairs(_espObjects) do
                if not active[name] then
                    removeESP(name)
                end
            end
        end)
    end
end)

